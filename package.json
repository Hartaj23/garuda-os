{
  "name": "garuda",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "Garuda OS engineering foundation",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "validate": "python3 scripts/run_checks.py",
    "test": "python3 -m unittest discover tests",
    "toolchain:check": "python3 scripts/validate_toolchain.py",
    "format:python": "black .",
    "lint:python": "ruff check .",
    "format:web": "prettier --check .",
    "lint:web": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
